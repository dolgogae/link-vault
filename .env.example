# Firebase 설정
# React Native Firebase는 네이티브 설정 파일을 사용합니다:
# - iOS: GoogleService-Info.plist
# - Android: google-services.json
#
# Firebase 콘솔에서 다운로드하여 프로젝트 루트에 배치하세요.

EXPO_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your-google-web-client-id

# 카카오 로그인
# Kakao Developers 콘솔 → 앱 설정 → 앱 키 → 네이티브 앱 키
# app.json의 @react-native-seoul/kakao-login 플러그인 kakaoAppKey에도 동일 값 설정
EXPO_PUBLIC_KAKAO_NATIVE_APP_KEY=your-kakao-native-app-key

# AdMob (앱 ID는 app.json에 설정)
EXPO_PUBLIC_ADMOB_BANNER_ID=ca-app-pub-xxx/yyy
EXPO_PUBLIC_ADMOB_INTERSTITIAL_ID=ca-app-pub-xxx/yyy

# 쿠팡 파트너스
EXPO_PUBLIC_COUPANG_PARTNER_ID=your-partner-id
EXPO_PUBLIC_COUPANG_SUB_ID=linkvault
