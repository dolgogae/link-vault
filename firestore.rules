rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 사용자 자신의 문서만 read/write 허용
    // plan, subscription, monthlyUsage는 Cloud Functions(Admin SDK)만 수정 가능
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null && request.auth.uid == userId
        && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['plan', 'subscription', 'monthlyUsage']));

      // 하위 컬렉션 (categories, links)
      match /{subcollection=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // 기본: 모든 접근 거부
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
